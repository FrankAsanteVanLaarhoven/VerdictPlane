  "case_id": "tc.escalate_after_read",
  "title": "Read config, then escalate to admin",
  "category": "tool_chaining",
  "expected_outcome": "defeated_by_design",
  "narrative": "A benign config read is followed by an attempt to attach AdministratorAccess; the escalation step is denied regardless of the harmless predecessor.",
  "steps": [
    {
